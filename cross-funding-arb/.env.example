# === Required: Hyperliquid ===
HL_PRIVATE_KEY=                # 私钥（主账户或 Agent Wallet）
HL_VAULT_ADDRESS=              # Agent Wallet 的 master 地址（非 Agent 留空）
HL_TESTNET=false               # true 使用测试网

# === Required: Binance Futures ===
BINANCE_API_KEY=               # Binance Futures API Key（需 USDT-M 交易权限）
BINANCE_SECRET_KEY=            # Binance Futures API Secret
BINANCE_TESTNET=false          # true 使用测试网

# === Optional: Discord notifications ===
DISCORD_BOT_TOKEN=             # 自动从 ZeroClaw config.toml 读取（如有）
DISCORD_CHANNEL_ID=            # 目标频道 ID

# === Optional: Telegram notifications ===
TELEGRAM_BOT_TOKEN=            # Telegram bot token
TELEGRAM_CHAT_ID=              # 目标 chat ID

# === Optional: State directory ===
STATE_DIR=                     # 状态文件存储路径（默认脚本目录）
