# === Required ===

# Hyperliquid private key (EIP-712 signing)
HL_PRIVATE_KEY=
# Optional: agent wallet mode (leave empty to sign directly with private key)
HL_VAULT_ADDRESS=
# Testnet mode (true/false)
HL_TESTNET=false

# Binance Futures API credentials
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Binance testnet (true/false)
BINANCE_TESTNET=false

# === Optional ===

# State file directory (defaults to script directory)
STATE_DIR=

# Notification (optional, silent if not configured)
# bot_token auto-reads from ~/.zeroclaw-strategy/config.toml, no need to set manually
# channel_id / chat_id must be configured per strategy
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
