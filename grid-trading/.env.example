# === Required: OKX API credentials ===
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# === Required: Wallet ===
WALLET_ADDR=0x...your_evm_address
ONCHAINOS_ACCOUNT_ID=       # optional, needed if you have multiple onchainos accounts

# === Optional: Discord notifications ===
DISCORD_CHANNEL_ID=
DISCORD_BOT_TOKEN=

# === Optional: Telegram notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
