# === Required: OKX API credentials ===
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# === Required: Wallet ===
WALLET_ADDR=0x...your_evm_address
ONCHAINOS_ACCOUNT_ID=       # required if you have multiple onchainos accounts

# === Optional: onchainos home ===
ONCHAINOS_HOME=             # defaults to ~/.onchainos

# === Optional: Discord notifications ===
DISCORD_CHANNEL_ID=         # auto-detected from ~/.openclaw/openclaw.json if empty
DISCORD_BOT_TOKEN=          # auto-detected from ~/.openclaw/openclaw.json if empty

# === Optional: Telegram notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Optional: Cross-platform portfolio ===
HL_WALLET_ADDR=             # Hyperliquid wallet address (public API, no auth)
BINANCE_API_KEY=            # Binance Futures read-only API key
BINANCE_SECRET_KEY=         # Binance Futures API secret
