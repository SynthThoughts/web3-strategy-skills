<?xml version="1.0" encoding="UTF-16"?>
<!--
  lp-auto Task Scheduler template (Windows)

  Install:
    schtasks /Create /XML <this-file> /TN "lp-auto {{INSTANCE}}" /F

  Start immediately:
    schtasks /Run /TN "lp-auto {{INSTANCE}}"

  Register with lp-auto so status can self-check:
    lp-auto --instance {{INSTANCE}} scheduler-register ^
        --type windows-task ^
        --id "lp-auto {{INSTANCE}}" ^
        --interval {{INTERVAL}}

  Notes:
    - LogonTrigger fires on user login; the task is restarted if it dies
      via Settings/RestartOnFailure.
    - Replace {{USER}} with DOMAIN\user or .\user as appropriate.
    - Python path is typically C:\Python311\python.exe or
      %LOCALAPPDATA%\Programs\Python\Python311\python.exe
-->
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>lp-auto V3 LP daemon ({{INSTANCE}})</Description>
  </RegistrationInfo>
  <Triggers>
    <LogonTrigger>
      <Enabled>true</Enabled>
      <UserId>{{USER}}</UserId>
    </LogonTrigger>
    <BootTrigger>
      <Enabled>true</Enabled>
    </BootTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <UserId>{{USER}}</UserId>
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>true</RunOnlyIfNetworkAvailable>
    <RestartOnFailure>
      <Interval>PT1M</Interval>
      <Count>10</Count>
    </RestartOnFailure>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>{{PYTHON}}</Command>
      <Arguments>"{{CLI}}" --instance {{INSTANCE}} daemon --interval {{INTERVAL}}</Arguments>
      <WorkingDirectory>{{HOME}}\.lp-auto\instances\{{INSTANCE}}</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
